# ─────────────────────────────────────────────────────────────────────────────
# FinnaCalc Tax Platform — environment template
# Copy to `.env.local` (gitignored) and fill in. Nothing here is required to
# build or run the marketing/calculator site; these power the tax-platform
# foundation (database + auth).
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string for the tax-platform data layer (db/).
# The app connects lazily at runtime — build and CI run without this set.
DATABASE_URL=postgres://user:password@localhost:5432/finnacalc

# Supabase — managed identity provider (lib/server/auth-supabase.ts) and the
# Postgres host you can point DATABASE_URL at. Leave unset to run with the no-op
# auth provider (anonymous mode); the marketing/calculator site still serves.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Publishable key (safe to expose to the browser; inlined at build time):
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxx
# Secret key — server-only; never commit, never expose to the client. Used by
# privileged server operations (admin tooling, RLS bypass).
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxx
