# ─────────────────────────────────────────────────────────────────────────────
# FinnaCalc Tax Platform — environment template
# Copy to `.env.local` (gitignored) and fill in. Nothing here is required to
# build or run the marketing/calculator site; these power the tax-platform
# foundation (database + auth).
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string for the tax-platform data layer (db/).
# The app connects lazily at runtime — build and CI run without this set.
DATABASE_URL=postgres://user:password@localhost:5432/finnacalc

# Managed identity provider (Clerk) — the production auth adapter
# (lib/server/auth-clerk.ts). Leave unset to run with the no-op provider.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
